# Local entrypoints and Docker Compose read this file.
NETHUNT_EMAIL=you@example.com
NETHUNT_API_KEY=replace-me
NETHUNT_BASE_URL=https://nethunt.com
NETHUNT_AUTOMATION_BASE_URL=https://nethunt.com
NETHUNT_AUTOMATION_COOKIE=
NETHUNT_AUTOMATION_EXTRA_HEADERS_JSON=
# See README.md for lifecycle + editor_operations manifest examples.
NETHUNT_AUTOMATION_MANIFEST_JSON={}
NETHUNT_TIMEZONE=Europe/Kiev
NETHUNT_LOG_LEVEL=INFO
MCP_TRANSPORT=stdio
MCP_HOST=127.0.0.1
MCP_PORT=18044
# Bearer token HTTP clients must present; leave blank to disable auth (ignored for stdio transport).
MCP_API_KEY=
# Public URL of this server used for OAuth metadata; defaults to http://MCP_HOST:MCP_PORT when MCP_API_KEY is set.
MCP_SERVER_URL=

# Telegram sidecar bot
TELEGRAM_BOT_TOKEN=
# Comma-separated Telegram numeric user IDs allowed to use the bot in private chat.
TELEGRAM_ALLOWED_USER_IDS=
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4
TELEGRAM_MCP_URL=http://127.0.0.1:18044/mcp
# Optional override; defaults to MCP_API_KEY when blank.
TELEGRAM_MCP_API_KEY=
